{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-root-app",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false,
			"problemMatcher": [
				"$tsc"
			],
			"group": "build"
		},
		{
			"label": "commit-push-cleanup",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				"-A",
				"&&",
				"git",
				"commit",
				"-m",
				"Remove redundant web wrapper",
				"&&",
				"git",
				"push",
				"origin",
				"main"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		}
	]
}